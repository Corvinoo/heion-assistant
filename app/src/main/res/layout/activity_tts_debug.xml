<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:fitsSystemWindows="true">

    <TextView
        android:id="@+id/txt_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Kokoro TTS Smoke Test"
        android:textSize="20sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btn_run_copy"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Run Model Copy &amp; Verify" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Test Sub-Menu"
        android:textStyle="bold" />

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none">
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <Button
                android:id="@+id/btn_test_engine"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Engine" />
            <Button
                android:id="@+id/btn_test_phonemizer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Phonemes" />
            <Button
                android:id="@+id/btn_test_lid"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LID" />
        </LinearLayout>
    </HorizontalScrollView>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Pipelines"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btn_test_full_pipeline"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Full Pipeline (LID + Router)" />

    <Button
        android:id="@+id/btn_test_streaming"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Streaming (Chunked)" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Italian Tests"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <Button
            android:id="@+id/btn_test_it_no_chunk"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="IT (No Chunk)" />
        <Button
            android:id="@+id/btn_test_it_streaming"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="IT (Streaming)" />
    </LinearLayout>

    <Button
        android:id="@+id/btn_test_english_only"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="English Only (Direct)" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="16dp"
        android:background="#EEEEEE">

        <TextView
            android:id="@+id/txt_log"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:fontFamily="monospace"
            android:text="Logs will appear here..." />
    </ScrollView>

</LinearLayout>
