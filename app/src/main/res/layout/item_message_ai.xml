<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="10dp"
    android:paddingVertical="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="3dp"
        android:paddingVertical="6dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

        <ImageView
            android:id="@+id/aiAvatar"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_assistant_spark"
            app:tint="#7C6AF5" />

        <TextView
            android:id="@+id/modelNameText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="ModelName"
            android:textSize="12sp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/bubbleContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="start"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_bubble_ai"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/statusContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:paddingHorizontal="14dp"
                android:paddingVertical="10dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:visibility="gone">

                <ProgressBar
                    android:id="@+id/statusProgress"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:indeterminate="true"
                    android:indeterminateTint="#7C6AF5"
                    style="?android:attr/progressBarStyleSmall" />

                <TextView
                    android:id="@+id/statusText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:textColor="#B0B0B4"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/thoughtContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="14dp"
                android:paddingTop="4dp"
                android:paddingBottom="8dp"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/thoughtText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#B0B0B4"
                    android:textSize="13sp"
                    android:textStyle="italic"
                    android:lineSpacingExtra="4dp"
                    android:padding="12dp"
                    android:background="@drawable/bg_thought_accent" />
            </LinearLayout>

            <TextView
                android:id="@+id/messageText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="14dp"
                android:paddingVertical="10dp"
                android:textSize="16sp"
                android:breakStrategy="simple"
                android:hyphenationFrequency="none"
                android:includeFontPadding="false"
                android:textColor="#F2F2F3"
                android:textIsSelectable="true"
                android:textColorLink="#7C6AF5" />

        </LinearLayout>
    </LinearLayout>
</FrameLayout>
